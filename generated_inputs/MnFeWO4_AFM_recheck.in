&CONTROL
  calculation = 'scf'
  prefix = 'MnFeWO4_AFM_recheck'
/
&SYSTEM
  ibrav = 0
  nat = 12
  ntyp = 3
  ecutwfc = 120.0
  ecutrho = 480.0
  nspin = 2
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
  starting_magnetization(1) = -0.5
/
&ELECTRONS
  conv_thr = 1e-09
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 200
/
HUBBARD (ortho-atomic)
U Mn-3d 4.65
U Fe-3d 5.30
K_POINTS automatic
  6 6 6 0 0 0

! ATOMIC_SPECIES, ATOMIC_POSITIONS, CELL_PARAMETERS: not in the source
! report, fill in from the actual relaxed structure first.
