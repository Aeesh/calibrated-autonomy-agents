&CONTROL
  calculation = 'scf'
  prefix = 'MnCdWO4_AFM_first_attempt'
/
&SYSTEM
  ibrav = 0
  nat = 12
  ntyp = 3
  ecutwfc = 120.0
  ecutrho = 480.0
  nspin = 2
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
/
&ELECTRONS
  conv_thr = 1e-09
  mixing_beta = 0.7
/
HUBBARD (ortho-atomic)
U Mn-3d 4.65
K_POINTS automatic
  6 6 6 0 0 0

! no U applied to Cd, not yet confirmed by linear response for this cation.
! ATOMIC_SPECIES, ATOMIC_POSITIONS, CELL_PARAMETERS: not in the source
! report, fill in from the actual relaxed structure first.
